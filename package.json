{
  "name": "insight-management",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 execute insight-management-db --local --file=./drizzle/0000_initial.sql",
    "db:migrate:remote": "wrangler d1 execute insight-management-db --remote --file=./drizzle/0000_initial.sql",
    "db:seed": "wrangler d1 execute insight-management-db --local --file=./src/worker/db/seed.sql",
    "db:seed:remote": "wrangler d1 execute insight-management-db --remote --file=./src/worker/db/seed.sql"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@cloudflare/workers-types": "^4.20260307.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "drizzle-kit": "^0.31.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wrangler": "^4.71.0"
  }
}
